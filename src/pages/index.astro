---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import portrait from '../assets/christian_sisti.jpg';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="Christian Sisti"
  description="Engineering Director specializing in scaling global engineering organizations and modernizing high-traffic platforms."
>
  <div class="py-8 flex items-center gap-12">
    <Image
      src={portrait}
      alt="Christian Sisti"
      width={512}
      height={512}
      quality={95}
      class="rounded-full object-cover shrink-0 ring-2 ring-warm-100 w-64 h-64"
    />
    <div>
      <p class="text-xs font-semibold tracking-widest uppercase text-navy-500 mb-4">Engineering Director</p>
      <h1 class="text-5xl font-semibold text-navy-950 leading-tight mb-6">
        Christian Sisti
      </h1>
      <p class="text-lg text-navy-700 leading-relaxed">
        Scaling engineering organizations. Modernizing high-traffic platforms.
        Building environments where technical excellence thrives.
      </p>
      <div class="mt-10 flex gap-6">
        <a href="/about" class="text-sm font-medium text-navy-900 border-b border-navy-900 pb-px hover:text-navy-500 hover:border-navy-500 transition-colors">
          About me
        </a>
      </div>
    </div>
  </div>

  <section class="mt-20">
    <h2 class="text-xs font-semibold tracking-widest uppercase text-navy-500 mb-8">Writing</h2>
    <div class="space-y-8">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="group block">
          <p class="text-xs text-navy-500 mb-1">
            {post.data.pubDate.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })}
          </p>
          <h3 class="text-lg font-medium text-navy-900 group-hover:text-navy-500 transition-colors mb-1">
            {post.data.title}
          </h3>
          <p class="text-sm text-navy-700">{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
