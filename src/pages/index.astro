---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Christian Sisti"
  description="Engineering Director specializing in scaling global engineering organizations and modernizing high-traffic platforms."
>
  <div class="py-8">
    <p class="text-xs font-semibold tracking-widest uppercase text-navy-500 mb-4">Engineering Director</p>
    <h1 class="text-5xl font-semibold text-navy-950 leading-tight mb-6">
      Christian Sisti
    </h1>
    <p class="text-lg text-navy-700 leading-relaxed max-w-xl">
      Scaling engineering organizations. Modernizing high-traffic platforms.
      Building environments where technical excellence thrives.
    </p>
    <div class="mt-10 flex gap-6">
      <a href="/about" class="text-sm font-medium text-navy-900 border-b border-navy-900 pb-px hover:text-navy-500 hover:border-navy-500 transition-colors">
        About me
      </a>
    </div>
  </div>
</Layout>
